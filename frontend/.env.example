# DISPATCH backend integration keys
# Leave blank for fallback demo mode where applicable.


# Supabase persistence (optional locally, recommended for production)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Shared secret used by external schedulers (Supabase Scheduler, etc.) to call /api/cron/generate
SCHEDULER_SECRET=


# Groq (recommended primary provider)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# OpenRouter fallback (Gemma 3 27B)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemma-3-27b-it:free

# Optional provider override: groq | anthropic | openrouter
AI_PROVIDER=groq

# NewsData.io topics API
NEWSDATA_API_KEY=your_key_here

# NewsAPI.org (primary trending topics + research fallback)
NEWSAPI_KEY=your_newsapi_key_here

# TheNewsAPI.com (primary per-topic research)
THENEWSAPI_KEY=your_thenewsapi_key_here

# GNews.io (topic fallback)
GNEWS_KEY=your_gnews_key_here

#virlo
VIRLO_API_KEY=