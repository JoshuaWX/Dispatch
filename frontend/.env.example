# DISPATCH backend integration keys
# Leave blank for fallback demo mode where applicable.


# Supabase persistence (optional locally, recommended for production)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Shared secret used by external schedulers (Supabase Scheduler, etc.) to call /api/cron/generate
SCHEDULER_SECRET=


# Groq (recommended primary provider)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Optional provider override: groq | anthropic
AI_PROVIDER=groq

# NewsData.io topics API
NEWSDATA_API_KEY=your_key_here
